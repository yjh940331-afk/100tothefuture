# ------------------------------------------------------------------
# 환경변수 예시. 로컬 개발용으로 .env.local 로 복사해 채우세요.
#   cp .env.example .env.local
# 배포(Cloudflare Workers)에서는 Wrangler secret 또는 대시보드 Variables 에 등록합니다.
# ------------------------------------------------------------------

# Supabase (프로젝트 > Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon public key

# 관리자 작업(예약/리뷰 상태 변경)에 필요한 service_role 키 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 관리자 페이지(/admin) 로그인 비밀번호 (강력하게 설정)
ADMIN_PASSWORD=change-me-to-strong-password

# 관리자 세션 서명용 secret (ADMIN_PASSWORD와 다른 긴 랜덤 문자열 권장)
ADMIN_SESSION_SECRET=change-me-to-a-long-random-session-secret

# 공개 사이트 URL. 실제 도메인 연결 전에는 workers.dev URL을 사용해도 됩니다.
NEXT_PUBLIC_SITE_URL=https://100tothefuture.your-subdomain.workers.dev

# 선택: 새 예약/예약 상태 변경을 받을 운영 webhook URL
# Slack, Discord, Make, Zapier 등 JSON webhook을 받는 URL을 넣습니다.
ADMIN_NOTIFICATION_WEBHOOK_URL=https://example.com/webhook
