# ------------------------------------------------------------------
# 환경변수 예시. 로컬 개발용으로 .env.local 로 복사해 채우세요.
#   cp .env.example .env.local
# 배포(Cloudflare Pages)에서는 대시보드 > Settings > Environment variables 에 등록합니다.
# ------------------------------------------------------------------

# Supabase (프로젝트 > Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # anon public key

# 관리자 작업(예약/리뷰 상태 변경)에 필요한 service_role 키 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 관리자 페이지(/admin) 로그인 비밀번호 (강력하게 설정)
ADMIN_PASSWORD=change-me-to-strong-password
